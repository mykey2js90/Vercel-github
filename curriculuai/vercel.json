{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/manus-storage/(.*)", "destination": "/api/index" },
    { "source": "/((?!_next|assets|favicon\\.ico|robots\\.txt).*)", "destination": "/index.html" }
  ]
}
